# ===========================================
# 环境变量配置示例
# 复制本文件为 .env 并填写实际值，.env 文件不会被提交到 Git
# ===========================================

# ---- 数据库配置 ----
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=test_auto

# ---- 本地登录服务数据库 ----
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=3306
LOCAL_DB_USER=root
LOCAL_DB_PASSWORD=your_local_db_password_here
LOCAL_DB_NAME=local_web_login

# ---- 生产环境数据库 ----
PROD_DB_HOST=your_prod_db_host
PROD_DB_PORT=3306
PROD_DB_USER=your_prod_db_user
PROD_DB_PASSWORD=your_prod_db_password_here
PROD_DB_NAME=test_auto

# ---- Linux 服务器 SSH ----
LINUX_HOST=192.168.138.129
LINUX_USER=root
LINUX_PASSWORD=your_ssh_password_here

# ---- 默认管理员密码（初始化数据库时使用）----
ADMIN_DEFAULT_PASSWORD=your_admin_password_here

# ---- JWT 密钥 ----
JWT_SECRET=your_jwt_secret_here

# ---- AI API Keys ----
DEEPSEEK_API_KEY=your_deepseek_api_key_here
QWEN_API_KEY=your_qwen_api_key_here
DOUBAO_API_KEY=your_doubao_api_key_here
ZHIPU_API_KEY=your_zhipu_api_key_here
MIMO_API_KEY=your_mimo_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=your_anthropic_api_key_here
MOONSHOT_API_KEY=your_moonshot_api_key_here

# ---- 性能测试账号密码 ----
PERF_USER_ADMIN=admin
PERF_PWD_ADMIN=your_perf_admin_password_here
PERF_USER_1=user
PERF_PWD_1=your_perf_user1_password_here
PERF_USER_2=student
PERF_PWD_2=your_perf_user2_password_here
PERF_USER_3=teacher
PERF_PWD_3=your_perf_user3_password_here

# ---- 电商平台请求头（可选）----
ECOMMERCE_ORIGIN=https://your-ecommerce-site.com
ECOMMERCE_REFERER=https://your-ecommerce-site.com/

# ---- 集成服务（可选）----
JENKINS_URL=https://your-jenkins-url.com
JENKINS_USER=your_jenkins_user
JENKINS_TOKEN=your_jenkins_token_here
ZENTAO_URL=https://your-zentao-url.com
ZENTAO_USER=your_zentao_user
ZENTAO_PASSWORD=your_zentao_password_here

# ---- 测试平台启用开关（conftest.py 使用）----
# ENABLE_ANDROID=1
# ENABLE_IOS=1
# ENABLE_HARMONY=1
# ENABLE_WINDOWS=1
# ENABLE_LINUX=1
# ENABLE_SERVICE=1

# ---- Flask 环境 ----
FLASK_ENV=development
